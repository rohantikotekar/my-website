# Backend environment (Express + Prisma).
# Copy to .env and fill in real values. Never commit .env.

# --- Database (Supabase Postgres) ---
# Supabase Dashboard → Connect → ORMs (Prisma). URL-encode special characters
# in the password (e.g. "@" -> "%40").
DATABASE_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"

# --- Email (Resend) ---
# Sandbox sender (onboarding@resend.dev) only delivers to your Resend account's
# OWN email. For production either make CONTACT_TO_EMAIL your Resend account email,
# or verify a domain at resend.com/domains and use a CONTACT_FROM_EMAIL on it.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
CONTACT_TO_EMAIL="you@example.com"
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"

# --- Server ---
# Local only. In production (Render) PORT is injected automatically — do NOT set it.
PORT=4000
# Comma-separate multiple origins. In production set this to your Vercel URL,
# e.g. CORS_ORIGIN="https://your-site.vercel.app"
CORS_ORIGIN="http://localhost:3000"

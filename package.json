{
  "name": "my-website",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack portfolio — Yosemite Trail. Monorepo: frontend (Next.js) + backend (Express + Prisma).",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "start": "concurrently -n backend,frontend -c blue,green \"npm:start:backend\" \"npm:start:frontend\"",
    "start:frontend": "npm run start --workspace frontend",
    "start:backend": "npm run start --workspace backend",
    "lint": "npm run lint --workspace frontend",
    "db:generate": "npm run db:generate --workspace backend",
    "db:migrate": "npm run db:migrate --workspace backend",
    "db:studio": "npm run db:studio --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
